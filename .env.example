# Database Configuration
# Set this to your Neon PostgreSQL connection string
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxxx.region.neon.tech/database?sslmode=require&channel_binding=require

# Authentication (Optional - for future auth implementation)
NEON_AUTH_COOKIE_SECRET=your-strong-random-secret-key-here

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Web3 Configuration (Optional)
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your_wallet_connect_project_id_here

# Analytics (Optional)
NEXT_PUBLIC_ANALYTICS_ID=your_analytics_id_here
